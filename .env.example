# Database
DATABASE_PATH=./data/qsa.db

# Auth — generate a long random string for production
# openssl rand -base64 64
AUTH_SECRET=replace-with-a-long-random-string-at-least-32-chars
SESSION_COOKIE_NAME=qsa_session
SESSION_DURATION_DAYS=30

# Admin bootstrap — first user with this email becomes admin on first login
ADMIN_EMAIL=juanaranedagattavara@gmail.com

# Mercado Pago (sandbox first, swap to production keys on go-live)
MERCADOPAGO_ACCESS_TOKEN=TEST-replace-me
MERCADOPAGO_PUBLIC_KEY=TEST-replace-me
MERCADOPAGO_WEBHOOK_SECRET=replace-with-random-string

# Email (Resend in production — currently logs to console)
RESEND_API_KEY=
EMAIL_FROM=QSA <noreply@quietstormanalytics.cl>

# App
APP_URL=http://localhost:3000

# UF rate source (mindicador.cl is free, no key needed)
UF_RATE_SOURCE=https://mindicador.cl/api/uf
